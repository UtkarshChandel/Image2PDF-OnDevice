{
  "name": "image-to-pdf-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:watch": "vitest",
    "wasm:build": "wasm-pack build wasm/image-core --target web --out-dir ../../src/wasm/pkg --out-name image2pdf_wasm --release"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.2"
}
